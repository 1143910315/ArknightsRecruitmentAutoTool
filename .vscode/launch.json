{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Wails: Production ArknightsRecruitmentAutoTool",
      "type": "go",
      "request": "launch",
      "mode": "exec",
      "program": "${workspaceFolder}/build/bin/ArknightsRecruitmentAutoTool.exe",
      "preLaunchTask": "build",
      "cwd": "${workspaceFolder}"
    },
    {
      "name": "Wails: Debug ArknightsRecruitmentAutoTool",
      "type": "go",
      "request": "launch",
      "mode": "exec",
      "program": "${workspaceFolder}/build/bin/ArknightsRecruitmentAutoTool.exe",
      "preLaunchTask": "wails build",
      "cwd": "${workspaceFolder}"
    },
    {
      "name": "Wails: Dev ArknightsRecruitmentAutoTool",
      "type": "go",
      "request": "attach",
      "mode": "remote",
      "remotePath": "${workspaceFolder}",
      "port": 2345,
      "host": "127.0.0.1",
      "preLaunchTask": "Start Debug Environment"
    }
  ]
}
